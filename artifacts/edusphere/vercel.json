{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "node scripts/build.mjs",
  "outputDirectory": "dist/public",
  "installCommand": "cd ../.. && pnpm install",
  "framework": null,
  "env": {
    "PORT": "5173",
    "BASE_PATH": "/"
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}

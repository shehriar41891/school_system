{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter @workspace/edusphere run build",
  "outputDirectory": "artifacts/edusphere/dist/public",
  "framework": null,
  "env": {
    "PORT": "5173",
    "BASE_PATH": "/",
    "NODE_ENV": "production"
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}

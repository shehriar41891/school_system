{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install",
  "buildCommand": "node artifacts/edusphere/scripts/build.mjs",
  "outputDirectory": "artifacts/edusphere/dist/public",
  "framework": null,
  "env": {
    "PORT": "5173",
    "BASE_PATH": "/"
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
